{
  "branches": [
    "main"
  ],
  "tagFormat": "Version_${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pwsh -NoLogo -NoProfile -File ./scripts/release/Prepare-SemanticRelease.ps1 -Version ${nextRelease.version} -ProjectFile project.json -ChangelogFile CHANGELOG.md",
        "publishCmd": "pwsh -NoLogo -NoProfile -File ./scripts/release/Publish-ToPSGallery.ps1 -ModulePath ./dist/NovaModuleTools"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "project.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
